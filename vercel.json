{
  "version": 2,
  "installCommand": "pip install -r requirements.txt && python scripts/generate_synthetic_epidata.py --seed 42 && python scripts/run_pipeline.py",
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python",
      "config": {
        "includeFiles": [
          "backend/**",
          "data/gold/**",
          "data/synthetic/**"
        ]
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "api/index.py"
    }
  ]
}
