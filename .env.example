# Backend (Render / local)
# Origens CORS permitidas (separadas por vírgula). Inclua a URL da Vercel em produção.
BACKEND_CORS_ORIGINS=http://localhost:3000

# Porta (Render injeta $PORT automaticamente; use para testes locais)
PORT=8000

# Frontend (Vercel)
# URL pública do backend FastAPI em produção.
NEXT_PUBLIC_API_URL=http://localhost:8000
