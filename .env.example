# Backend (local / Render / Vercel Python)
# Origens CORS permitidas (separadas por vírgula).
# Produção: inclua a URL do frontend Vercel.
BACKEND_CORS_ORIGINS=http://localhost:3000,https://sentinelasus.vercel.app

# Porta do Uvicorn (Render/Vercel injetam $PORT automaticamente)
PORT=8000

# Frontend (Next.js) — bake-time no `next build`
# Local: http://localhost:8000
# Produção: https://sentinelasus-api.vercel.app
NEXT_PUBLIC_API_URL=http://localhost:8000
